{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "paths": {
      "@hamr/agent": ["../agent/dist/index.d.ts"],
      "@hamr/agent/*": ["../agent/dist/*.d.ts"],
      "@hamr/ai": ["../ai/dist/index.d.ts"],
      "@hamr/ai/*": ["../ai/dist/*.d.ts", "../ai/dist/providers/*.d.ts"]
    },
    "rootDir": "./src"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/__tests__", "**/*.d.ts", "src/**/*.d.ts"]
}
