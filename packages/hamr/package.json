{
  "name": "@skaft/hamr",
  "version": "0.1.0",
  "description": "Local-first coding agent for consumer-GPU developers",
  "type": "module",
  "bin": {
    "hamr": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "tsgo -p tsconfig.build.json",
    "test": "vitest --run"
  },
  "dependencies": {
    "@hamr/agent": "*",
    "@hamr/ai": "*",
    "chalk": "5.6.2",
    "commander": "^14.0.0",
    "cross-spawn": "7.0.6",
    "diff": "8.0.4",
    "proper-lockfile": "4.1.2",
    "sexy-tui-rs": "*",
    "toml": "^3.0.0",
    "typebox": "1.1.38"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.9.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/cross-spawn": "6.0.6",
    "@types/diff": "7.0.2",
    "@types/node": "^22.0.0",
    "@types/proper-lockfile": "4.1.4",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  },
  "author": "Hamr contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/achuthanmukundan00/hamr.git",
    "directory": "packages/hamr"
  }
}
